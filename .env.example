# Copy to .env and adjust. docker compose reads .env automatically; for local
# `go run`, export the vars or use a tool like direnv.

# --- MQTT broker (shared by all services) ---
MQTT_BROKER_URL=tcp://localhost:1883
# MQTT_USERNAME=
# MQTT_PASSWORD=
MQTT_QOS=1
MQTT_KEEPALIVE=30s
MQTT_CONNECT_RETRY=5s

# --- Gateway (runs on the mini PC) ---
GATEWAY_HTTP_ADDR=:8080
SITE=default

# --- AI service (runs on the Jetson Nano / MacBook Air) ---
AI_HTTP_ADDR=:8081
AI_MODEL=threshold-v0

# --- Sensor simulator (stands in for the mesh network) ---
SIM_TARGET_URL=http://localhost:8080/ingest
SIM_SITE=default
SIM_NODES=3
SIM_SENSORS=temperature,humidity,vibration
SIM_INTERVAL=2s
