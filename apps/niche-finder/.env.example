# niche-finder configuration. Copy to .env (compose auto-reads it).
# `edge up`/`edge deploy` inject LLM_BASE_URL from fleet.json; the rest are local.

# --- LLM cluster (Qwen, via HAProxy) ---
# LLM_BASE_URL=http://host.docker.internal:11434
# The Qwen tag your cluster serves. Pull it first, e.g.:
#   ./edge model set qwen2.5:14b
LLM_MODEL=qwen2.5:14b

# --- Seed categories ---
# High-level categories to find niches within; the AI expands each into long-tail
# SEO keywords (you don't supply keywords). Comma-separated. Leave empty for fully
# autonomous discovery from the Reddit/Trends leads. (The UI can override these.)
# SEED_CATEGORIES=Cookbooks,Printable planners,Wall art prints,SVG cut files

# --- Mining sources ---
# Adapter spec: "name:arg,arg;name:...". Always-on, no keys needed:
#   reddit:<sub>,<sub>   hot posts per subreddit
#   gtrends:             today's trending search queries (US)
NICHE_SOURCES=reddit:somethingimade,Etsy,crafts,hobbies;gtrends:
# Items pulled per source.
MINE_LIMIT=25

# --- Etsy (optional) ---
# Set an Etsy Open API v3 keystring to enable: (1) Etsy as a mining source and
# (2) Etsy's active-listing `count` as the preferred, measured saturation signal.
# Get a key (key-only, no OAuth needed for active-listing search) at
# https://www.etsy.com/developers . Leave empty to skip Etsy entirely.
# ETSY_API_KEY=

# --- Saturation meter ---
# Order of measured backends to try; falls back to an LLM estimate if none work.
# etsy is used only when ETSY_API_KEY is set, else it's skipped.
SATURATION_MARKETS=etsy,ebay

# Host port for the dashboard (container always listens on 8820).
# NICHE_PORT=8820
