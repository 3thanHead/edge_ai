#!/usr/bin/env bash
# Root launcher for the iot_ai control CLI (Linux/macOS).
# Usage:  ./iot <command> [args]   e.g.  ./iot doctor   ./iot up camera-vision
set -euo pipefail
HERE="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PY="$(command -v python3 || command -v python || true)"
if [ -z "$PY" ]; then
  echo "Python 3 is required but was not found on PATH." >&2
  exit 1
fi
exec "$PY" "$HERE/tools/iotctl/iotctl.py" "$@"
